# Rust / Cargo build artefacts
target/
**/target/

# Rust dep-graph lockfile is checked in (Cargo.toml ref). Keep Cargo.lock.

# Noir circuit build outputs (regenerated by scripts/hello_proof.sh and
# scripts/commitment_demo.sh)
circuits/**/target/
prover/**/target/

# Stellar runtime artefacts (regenerated by every demo script run)
.contract_id
.commitment_contract_id
.match_verifier_contract_id

# Match-circuit test snapshots (empty dir; kept by nargo)
circuits/match/tests/

# Editor / OS
.DS_Store
*.swp
.vscode/
.idea/

# Cargo test output (autogenerated by `cargo test`; we don't diff these)
**/test_snapshots/
